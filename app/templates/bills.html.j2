{% extends "base.html.j2" %}
{% set page_title = "Factures - " ~ (visitor.nick or visitor.full_name) %}

{% block styles %}
<style>
.bills-table {
    width: 100%;
    border-collapse: collapse;
}
.bills-table th,
.bills-table td {
    padding: 0.5em 0.75em;
    text-align: left;
    border-bottom: 1px solid #eee;
    vertical-align: middle;
}
.bills-table th {
    font-weight: bold;
    color: gray;
    font-size: 0.85em;
    text-transform: uppercase;
}
.bills-table tbody tr {
    cursor: pointer;
}
.bills-table tr:hover td {
    background: #f9f9f9;
}
.bills-table input[type="checkbox"] {
    position: static;
    opacity: 1;
    pointer-events: auto;
    appearance: auto;
    -webkit-appearance: checkbox;
    width: auto;
    height: auto;
    vertical-align: middle;
}
.pager {
    display: flex;
    gap: 1em;
    margin-top: 1em;
    justify-content: center;
    align-items: center;
}
.pager a {
    min-width: 8em;
    text-align: center;
}
</style>
{% endblock %}

{% block content %}
<div class="container">
    <a class="btn-flat" style="margin-top:1em;display:inline-block;" href="{{ url_for('.calendar_day', month=opening_date | arrow('format', 'YYYY-MM'), day=opening_date | arrow('format', 'DD')) }}">
        <i class="material-icons left">arrow_back</i>Retour au {{ opening_date | arrow('format', 'D MMM YYYY') }}
    </a>
    <h1>
        Associer des factures
        <small class="grey-text">- {{ visitor.nick or visitor.full_name }} {{ opening_date | arrow('format', 'D MMM YYYY') }}</small>
    </h1>

    {% if error %}
    <div class="card-panel red lighten-4">
        Erreur SumUp&nbsp;: {{ error }}
    </div>
    {% endif %}

    {% if transactions %}
    <div class="widget">
        <table class="bills-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Date</th>
                    <th>Montant</th>
                    <th>Moyen</th>
                    <th>Carte</th>
                    <th>Caissier</th>
                    <th>Référence</th>
                </tr>
            </thead>
            <tbody>
                {% for tx in transactions %}
                <tr>
                    <td>
                        <input
                            type="checkbox"
                            class="bill-checkbox"
                            data-reference="{{ tx.transaction_code }}"
                            data-amount="{{ tx.amount }}"
                            data-timestamp="{{ tx.timestamp }}"
                            data-cashier="{{ tx.user or '' }}"
                            data-payment-type="{{ tx.payment_type or '' }}"
                            {% if tx.transaction_code in linked_refs %}checked{% endif %}
                        >
                    </td>
                    <td>{{ tx.timestamp | arrow('format', 'D MMM YYYY HH:mm') }}</td>
                    <td>{{ "%.2f" | format(tx.amount) }}&thinsp;{{ tx.currency }}</td>
                    <td>{{ tx.moyen }}</td>
                    <td style="text-align:center;">
                        {% if tx.card_logo_url %}
                        <img src="{{ tx.card_logo_url }}" alt="{{ tx.card_type }}" title="{{ tx.card_type }}" height="20" style="vertical-align:middle;">
                        {% else %}
                        {{ tx.card_type or '—' }}
                        {% endif %}
                    </td>
                    <td>{{ tx.user or '—' }}</td>
                    <td><code>{{ tx.transaction_code }}</code></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="pager">
            {% if 'prev_oldest_ref' in links %}
            <a class="btn waves-effect waves-light" href="?oldest_ref={{ links['prev_oldest_ref'] }}">
                <i class="material-icons left">chevron_left</i>Précédent
            </a>
            {% endif %}
            {% if 'next_newest_ref' in links %}
            <a class="btn waves-effect waves-light" href="?newest_ref={{ links['next_newest_ref'] }}">
                Suivant<i class="material-icons right">chevron_right</i>
            </a>
            {% endif %}
        </div>
    </div>
    {% elif not error %}
    <p class="grey-text">Aucune transaction trouvée.</p>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const openingId = {{ opening_id | tojson }};
    const visitorId = {{ visitor_id | tojson }};

    for (const row of document.querySelectorAll('.bills-table tbody tr')) {
        row.addEventListener('click', (e) => {
            if (e.target.closest('input[type="checkbox"]')) return;
            const cb = row.querySelector('.bill-checkbox');
            if (cb) cb.click();
        });
    }

    for (const cb of document.querySelectorAll('.bill-checkbox')) {
        cb.addEventListener('change', async () => {
            const ref = cb.dataset.reference;
            if (cb.checked) {
                await fetch(`/api/openings/${openingId}/visitors/${visitorId}/bills`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reference: ref,
                        amount: parseFloat(cb.dataset.amount),
                        timestamp: cb.dataset.timestamp,
                        cashier: cb.dataset.cashier,
                        payment_type: cb.dataset.paymentType,
                    }),
                });
            } else {
                await fetch(`/api/openings/${openingId}/visitors/${visitorId}/bills/${encodeURIComponent(ref)}`, {
                    method: 'DELETE',
                });
            }
        });
    }
});
</script>
{% endblock %}
